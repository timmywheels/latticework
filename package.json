{
  "name": "latticework",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 14771",
    "build": "tsc -b && vite build && npm run og:generate",
    "lint": "oxlint",
    "preview": "vite preview",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "og:generate": "tsx --tsconfig tsconfig.server.json scripts/generate-og.ts",
    "worker:dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.3",
    "hono": "^4.12.30",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1",
    "resend": "^6.12.2",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.112.0"
  }
}
