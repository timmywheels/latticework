{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "@cloudflare/workers-types"
    ]
  },
  "include": [
    "server/**/*",
    "scripts/**/*",
    "src/data/**/*",
    "src/components/DisciplinePlates.tsx",
    "src/components/PlateArt.tsx"
  ]
}